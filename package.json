		"typescript-eslint": "^8.57.2",
		"vite": "^7.3.1",
		"vite-plugin-devtools-json": "^1.0.0"
	},
	"dependencies": {
		"@lucide/svelte": "^0.562.0",
		"mode-watcher": "^1.1.0",
		"svelte-inview": "^4.0.4",
		"svelte-motion": "^0.12.2"
